# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Google API key — used by GeminiEmbedder, GeminiGenerator, GeminiJudge
GOOGLE_API_KEY=

# Isaacus API key — used by Kanon2Embedder
ISAACUS_API_KEY=

# HuggingFace model cache — override to keep large models off your home directory
# On the UBC cluster, point this to your scratch space
HF_HOME=/scratch/<your_id>/hf_cache

# NLTK data directory — override to avoid writing to ~/nltk_data
NLTK_DATA=/scratch/<your_id>/nltk_data
